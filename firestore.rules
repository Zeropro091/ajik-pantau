rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email_verified == true && (request.auth.token.email == "putuari0911@gmail.com" || request.auth.token.email == "sucayaputra8@gmail.com" || request.auth.token.email == "madejayasedana20004@gmail.com"))
      );
    }

    function isValidReport(report) {
      let allowedKeys = ['reporterName', 'reporterPhone', 'description', 'status', 'mediaType', 'mediaUrl', 'trackingInfo', 'isPublic', 'createdAt', 'updatedAt'];
      let keysDiff = report.diff({});
      return keysDiff.affectedKeys().hasOnly(allowedKeys)
          && report.keys().hasAll(['reporterName', 'reporterPhone', 'description', 'status', 'mediaType', 'createdAt', 'updatedAt'])
          && report.reporterName is string && report.reporterName.size() > 0 && report.reporterName.size() <= 100
          && report.reporterPhone is string && report.reporterPhone.size() > 0 && report.reporterPhone.size() <= 30
          && report.description is string && report.description.size() > 0 && report.description.size() <= 2000
          && report.status in ['pending', 'processing', 'completed']
          && (report.mediaType in ['image', 'video', 'none'])
          && (report.get('mediaUrl', '') is string)
          && (report.get('mediaUrl', '').size() <= 1048576) // max 1MB for base64 image limit, roughly
          && (report.get('isPublic', true) is bool)
          && (!('trackingInfo' in report) || (report.trackingInfo is map && report.trackingInfo.get('fingerprint', '') is string && report.trackingInfo.get('userAgent', '') is string))
          && report.createdAt == request.time
          && report.updatedAt == request.time;
    }

    match /reports/{reportId} {
      // Anyone can submit a report
      allow create: if isValidReport(request.resource.data);
      
      // Allow public list of reports for the feed
      allow list: if (resource.data.status in ['pending', 'processing', 'completed'] && resource.data.get('isPublic', true) == true) || isAdmin();
      
      // Allow getting specific report
      allow get: if true;
      
      // Only authenticated admins can update and delete
      allow update: if (
        isAdmin() &&
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'isPublic', 'updatedAt']) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'isPublic', 'updatedAt']) &&
        request.resource.data.status in ['pending', 'processing', 'completed'] &&
        (request.resource.data.get('isPublic', true) is bool) &&
        request.resource.data.updatedAt == request.time
      );
      
      allow delete: if isAdmin();
    }

    match /admins/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }
  }
}
